
generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url = env("DATABASE_URL")
}

model User {
    id       String @id @default(cuid())
    email    String @unique
    password String
    name     String
    role     Role   @default(USER)
    teamId   String?
    team     Team?  @relation(fields: [teamId], references: [id], onDelete: SetNull)
     
    // Time
    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")


    @@index([email])
    @@index([teamId])
    @@index([role])
    
    // Map table name to database
    @@map("users")
}

model Team {
    id          String  @id @default(cuid())
    name        String  @unique
    description String?
    code        String  @unique
    members     User[]  // Connects back to the capitalized User model
    
    // Time
    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")
 
    // Map table name to database
    @@map("teams")
}

enum Role {
    ADMIN
    MANAGER
    USER
    GUEST
}
